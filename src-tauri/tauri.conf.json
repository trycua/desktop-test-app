{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-test-app",
  "version": "0.1.0",
  "identifier": "com.trycua.desktop-test-app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Desktop Test App",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
